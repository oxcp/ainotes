{
  "$schema": "https://azuremlschemas.azureedge.net/latest/agent.schema.json",
  "name": "maf-agent-basic-resp",
  "display_name": "MAF Agent Basic Responses",
  "description": "Hosted agent for the maf-agent-basic-resp Foundry project with APIM-routed model calls.",
  "version": "1.0",
  "type": "host_agent",
  "properties": {
    "idle_timeout_minutes": 30,
    "scale_to_zero": true,
    "state_store": {
      "type": "redis",
      "connection_string_secret": {
        "key_vault_uri": "https://kv-agenthost-<deploymentSuffix>.vault.azure.net/",
        "secret_name": "redis-connection-string"
      },
      "fallback": {
        "type": "blob",
        "container": "agent-state",
        "storage_account": "stcagenthost<deploymentSuffix>"
      }
    },
    "auth": {
      "type": "managed_identity",
      "identity_resource_id": "/subscriptions/{subscriptionId}/resourceGroups/rg-agenthost-workshop/providers/Microsoft.ManagedIdentity/userAssignedIdentities/id-agenthost-<deploymentSuffix>"
    },
    "llm_backend": {
      "endpoint": "https://apim-agenthost-<deploymentSuffix>.azure-api.net/llm-api",
      "model": "gpt-5.4-mini",
      "api_version": "2024-02-01"
    }
  },
  "environment_variables": {
    "AGENT_LOG_LEVEL": "INFO",
    "AGENT_STATE_BACKEND": "redis",
    "AGENT_REDIS_TTL_SECONDS": "3600",
    "AGENT_BLOB_CONTAINER": "agent-state"
  }
}
