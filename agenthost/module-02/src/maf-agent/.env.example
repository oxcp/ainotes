# Choose how the agent reaches the model: "gateway" (default) or "direct".
MODEL_ROUTING="gateway"

# --- gateway mode: call the model THROUGH the module-01 APIM AI gateway ---
APIM_GATEWAY_URL="https://apim-agenthost-<SN>.azure-api.net/foundry"   # module-01 output: apimFoundryGatewayUrl
APIM_AUDIENCE="api://agenthost"                                        # module-01 param:  apimAudience

# --- direct mode: call the Foundry project endpoint directly ---
FOUNDRY_PROJECT_ENDPOINT="https://foundry-agenthost-<SN>.services.ai.azure.com/api/projects/maf-agent-prj"  # module-01 output: foundryProjectEndpoint

# Shared
AZURE_AI_MODEL_DEPLOYMENT_NAME="gpt-5.4-mini"                          # module-01 output: modelDeploymentName
