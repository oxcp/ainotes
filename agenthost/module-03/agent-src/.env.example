# agent-src — Environment configuration
# Copy to `.env` for local runs. In AKS these are injected by agent-sandbox.yaml.

# ── Agent ──────────────────────────────────────────────────────────────────
AGENT_ID=agent-poc-001
AGENT_PORT=8080
AGENT_LOG_LEVEL=INFO
# Run a short self-demo on startup (local only): true|false
AGENT_RUN_DEMO=true

# ── State backend: memory | redis ──────────────────────────────────────────
AGENT_STATE_BACKEND=memory

# Local Redis (Docker):        localhost:6379
# Azure Managed Redis (SSL):   <host>:10000,password=<key>,ssl=True,abortConnect=False
AGENT_REDIS_CONNECTION=localhost:6379
AGENT_REDIS_TTL_SECONDS=3600

# ── LLM endpoint (Foundry via APIM AI gateway) ─────────────────────────────
# The app uses the Microsoft Agent Framework (Agent + OpenAIChatClient).
# base_url points at the gateway; the client calls Foundry through it.
# Option A — APIM gateway base (in AKS); the app appends /openai/v1:
AGENT_APIM_ENDPOINT=https://apim-agenthost-<SN>.azure-api.net/foundry
LLM_MODEL=gpt-5.4-mini
AGENT_INSTRUCTIONS=You are a concise, helpful reflection agent. Keep answers brief.

# Option B — full client base_url (overrides AGENT_APIM_ENDPOINT):
# LLM_BASE_URL=https://apim-agenthost-<SN>.azure-api.net/foundry/openai/v1

# ── Authorization (Bearer token) ───────────────────────────────────────────
# Static key (local dev). Leave EMPTY in AKS to use Workload Identity instead.
LLM_API_KEY=
# AAD scope for the Workload Identity token. The Module 1 gateway validate-jwt
# checks the issuer only (not the audience), so the Foundry data-plane scope works:
LLM_TOKEN_SCOPE=https://ai.azure.com/.default
