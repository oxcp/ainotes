# app/.env — Local environment configuration for main.py
# In AKS most values are injected by agent-sandbox.yaml.

# ── Process / HTTP server ──────────────────────────────────────────────────
AGENT_ID=agent-poc-001
AGENT_PORT=8080
AGENT_LOG_LEVEL=INFO
# Run a short startup chat demo locally: true|false
AGENT_RUN_DEMO=true

# ── State persistence: Azure Blob ──────────────────────────────────────────
# The app stores conversation state as <AGENT_ID>.json in this container.
# Leave AGENT_STORAGE_ACCOUNT empty for local runs without Blob persistence.
AGENT_STORAGE_ACCOUNT=
AGENT_BLOB_CONTAINER=agent-state

# ── Foundry catalog agent registration ─────────────────────────────────────
# The app creates or reuses a persistent agent in this Foundry project so it is
# visible and manageable in the Foundry agent catalog.
FOUNDRY_PROJECT_ENDPOINT=https://foundry-agenthost-35153d.services.ai.azure.com/api/projects/maf-agent-prj
FOUNDRY_AGENT_NAME=agenthost-reflection-agent

# ── Model inference: Responses API through APIM ────────────────────────────
# main.py appends /openai/v1 to AGENT_APIM_ENDPOINT.
AGENT_APIM_ENDPOINT=https://apim-agenthost-35153d.azure-api.net/foundry
LLM_MODEL=gpt-5.4-mini
AGENT_INSTRUCTIONS=You are a concise, helpful assistant. Keep answers brief.

# ── Authentication / authorization ─────────────────────────────────────────
# The app uses DefaultAzureCredential (Workload Identity in AKS, developer login locally).
# This scope is used to fetch the Bearer token forwarded to APIM.
LLM_TOKEN_SCOPE=https://ai.azure.com/.default
