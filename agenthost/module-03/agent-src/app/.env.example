# agent-src — Environment configuration
# Copy to `.env` for local runs. In AKS these are injected by agent-sandbox.yaml.

# ── Agent ──────────────────────────────────────────────────────────────────
AGENT_ID=agent-poc-001
AGENT_PORT=8080
AGENT_LOG_LEVEL=INFO
# Run a short self-demo on startup (local only): true|false
AGENT_RUN_DEMO=true

# ── State backend: memory | redis ──────────────────────────────────────────
AGENT_STATE_BACKEND=memory

# Local Redis (Docker):        localhost:6379
# Azure Cache for Redis (SSL): <host>:6380,password=<key>,ssl=True
AGENT_REDIS_CONNECTION=localhost:6379
AGENT_REDIS_TTL_SECONDS=3600

# ── Agent mode ─────────────────────────────────────────────────────────────
# foundry: create a PERSISTENT agent in the Foundry project (visible in the
#          Foundry catalog / playground). Model calls route through APIM via the
#          Module 1 Foundry AI Gateway connection registered on the project.
# gateway: call the model through APIM directly (NOT visible in the catalog).
AGENT_MODE=foundry

# ── Foundry mode (AGENT_MODE=foundry) ──────────────────────────────────────
# Module 1 project endpoint (same format as its foundryProjectEndpoint output):
FOUNDRY_PROJECT_ENDPOINT=https://foundry-agenthost-<SN>.services.ai.azure.com/api/projects/maf-agent-prj
FOUNDRY_AGENT_NAME=agenthost-reflection-agent
LLM_MODEL=gpt-5.4-mini
AGENT_INSTRUCTIONS=You are a concise, helpful reflection agent. Keep answers brief.

# ── Gateway mode (AGENT_MODE=gateway) ──────────────────────────────────────
# APIM gateway base (the app appends /openai/v1):
# AGENT_APIM_ENDPOINT=https://apim-agenthost-<SN>.azure-api.net/foundry
# Or full client base_url (overrides AGENT_APIM_ENDPOINT):
# LLM_BASE_URL=https://apim-agenthost-<SN>.azure-api.net/foundry/openai/v1

# ── Authorization ──────────────────────────────────────────────────────────
# foundry mode: uses DefaultAzureCredential (needs "Azure AI User" on the project).
# gateway mode: static key (local dev), or empty to use Workload Identity.
LLM_API_KEY=
# AAD scope for the Workload Identity token (gateway mode). The Module 1 gateway
# validate-jwt checks the issuer only (not the audience):
LLM_TOKEN_SCOPE=https://ai.azure.com/.default
