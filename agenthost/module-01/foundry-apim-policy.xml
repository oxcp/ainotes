<!--
  foundry-apim-policy.xml — Module 1: reference APIM policy for the Foundry AI gateway
  Reference only. The live gateway policy is provisioned inline by core.bicep
  (var gatewayPolicyXml) and by setup.sh. Use this file as a richer starting
  point (validate-jwt, rate-limit, caching) that you can merge into the
  "foundry-ai-gateway" API scoped to the "foundry-host-agent" backend.

  Inbound:
    1. validate-jwt   — verify Entra ID token (Managed Identity credential from the agent)
    2. rate-limit-by-key — per-agent token quota (100 calls / 60 s)
    3. set-backend-service — route to the Foundry Host Agent runtime endpoint
    4. set-header — propagate agent-id for traceability
  Backend:
    5. retry — exponential back-off on 429 / 5xx
  Outbound:
    6. cache-store — cache identical prompt responses for 60 s
-->
<policies>
  <inbound>
    <base />

    <!-- 1. Validate Entra ID JWT (issued to Managed Identity of the agent) -->
    <validate-jwt header-name="Authorization" failed-validation-httpcode="401" failed-validation-error-message="Unauthorized: token validation failed">
      <openid-config url="https://login.microsoftonline.com/{{TenantId}}/v2.0/.well-known/openid-configuration" />
      <audiences>
        <audience>{{ApimAudience}}</audience>
      </audiences>
      <issuers>
        <issuer>https://sts.windows.net/{{TenantId}}/</issuer>
        <issuer>https://login.microsoftonline.com/{{TenantId}}/v2.0</issuer>
      </issuers>
    </validate-jwt>

    <!-- 2. Per-agent rate limiting -->
    <rate-limit-by-key calls="100" renewal-period="60"
      counter-key="@(context.Request.Headers.GetValueOrDefault("x-agent-id", context.Subscription.Id))" />

    <!-- 3. Route to Foundry Host Agent runtime -->
    <set-backend-service backend-id="foundry-host-agent" />

    <!-- 4. Forward agent-id for log traceability -->
    <set-header name="x-agent-id" exists-action="skip">
      <value>@(context.Request.Headers.GetValueOrDefault("x-agent-id", "unknown"))</value>
    </set-header>

    <!-- Cache lookup: skip cache for non-GET or streaming requests -->
    <cache-lookup vary-by-developer="false" vary-by-developer-groups="false" downstream-caching-type="none">
      <vary-by-header>x-agent-id</vary-by-header>
    </cache-lookup>
  </inbound>

  <backend>
    <!-- 5. Retry on throttle and transient errors -->
    <retry condition="@(context.Response.StatusCode == 429 || context.Response.StatusCode >= 500)" count="3" interval="2" max-interval="10" delta="1" first-fast-retry="false">
      <forward-request />
    </retry>
  </backend>

  <outbound>
    <base />
    <!-- 6. Cache successful responses for 60 s to reduce LLM costs -->
    <cache-store duration="60" />
  </outbound>

  <on-error>
    <base />
    <return-response>
      <set-status code="@(context.Response.StatusCode)" reason="@(context.Response.StatusReason)" />
      <set-header name="Content-Type" exists-action="override">
        <value>application/json</value>
      </set-header>
      <set-body>@("{\"error\":{\"code\":\"" + context.Response.StatusCode.ToString() + "\",\"message\":\"" + context.LastError.Message + "\"}}")</set-body>
    </return-response>
  </on-error>
</policies>
