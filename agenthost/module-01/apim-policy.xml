<!--
  apim-policy.xml — Module 1: APIM inbound policy for the LLM API
  Apply to the "llm-api" API (all operations) in Azure API Management.

  Policies applied (inbound):
    1. validate-jwt   — verify Entra ID token from the agent Workload Identity
    2. rate-limit-by-key — per-caller token quota
    3. set-backend-service — route to Azure OpenAI backend
  Policies applied (backend):
    4. retry — exponential back-off on 429 / 5xx
  Policies applied (outbound):
    5. azure-openai-token-limit — semantic token counting header passthrough
-->
<policies>
  <inbound>
    <base />

    <!-- 1. Validate Entra ID JWT issued by the tenant -->
    <validate-jwt header-name="Authorization" failed-validation-httpcode="401" failed-validation-error-message="Unauthorized: invalid or missing token">
      <openid-config url="https://login.microsoftonline.com/{{TenantId}}/v2.0/.well-known/openid-configuration" />
      <audiences>
        <audience>{{ApimAudience}}</audience>
      </audiences>
      <issuers>
        <issuer>https://sts.windows.net/{{TenantId}}/</issuer>
        <issuer>https://login.microsoftonline.com/{{TenantId}}/v2.0</issuer>
      </issuers>
      <required-claims>
        <claim name="roles" match="any">
          <value>AgentHost.Invoke</value>
        </claim>
      </required-claims>
    </validate-jwt>

    <!-- 2. Rate-limit by caller subscription key (100 calls / 60 s) -->
    <!--rate-limit-by-key calls="100" renewal-period="60" counter-key="@(context.Subscription.Id)" /-->

    <!-- 3. Route to the Azure OpenAI backend registered in Module 1 -->
    <set-backend-service backend-id="azure-openai" />

    <!-- Forward the agent-id header for traceability -->
    <set-header name="x-agent-id" exists-action="skip">
      <value>@(context.Request.Headers.GetValueOrDefault("x-agent-id", "unknown"))</value>
    </set-header>
  </inbound>

  <backend>
    <!-- 4. Retry on throttle (429) and transient errors (5xx) -->
    <retry condition="@(context.Response.StatusCode == 429 || context.Response.StatusCode >= 500)" count="3" interval="2" max-interval="10" delta="1" first-fast-retry="false">
      <forward-request />
    </retry>
  </backend>

  <outbound>
    <base />
    <!-- 5. Pass token-usage headers back to the caller for quota tracking -->
    <set-header name="x-openai-prompt-tokens" exists-action="override">
      <value>@(context.Response.Headers.GetValueOrDefault("x-ms-prompt-tokens", "0"))</value>
    </set-header>
    <set-header name="x-openai-completion-tokens" exists-action="override">
      <value>@(context.Response.Headers.GetValueOrDefault("x-ms-completion-tokens", "0"))</value>
    </set-header>
  </outbound>

  <on-error>
    <base />
    <return-response>
      <set-status code="@(context.Response.StatusCode)" reason="@(context.Response.StatusReason)" />
      <set-header name="Content-Type" exists-action="override">
        <value>application/json</value>
      </set-header>
      <set-body>@("{\"error\":{\"code\":\"" + context.Response.StatusCode.ToString() + "\",\"message\":\"" + context.LastError.Message + "\"}}")</set-body>
    </return-response>
  </on-error>
</policies>
