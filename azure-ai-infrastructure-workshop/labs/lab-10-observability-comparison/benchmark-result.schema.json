{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "platform": {
      "type": "string",
      "description": "Platform label, e.g. aks-kaito, anyscale-ray-serve, foundry-managed-compute, fireworks-on-foundry"
    },
    "billing_model": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "compute_core_hours",
        "node_uptime",
        "per_token",
        null
      ],
      "description": "How the platform bills: dedicated compute (KAITO/Foundry managed compute), node uptime (self-managed), or per-token (partner MaaS such as Fireworks on Foundry)"
    },
    "workload": {
      "type": "string"
    },
    "model": {
      "type": [
        "string",
        "null"
      ]
    },
    "gpu_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "gpu_count": {
      "type": [
        "integer",
        "null"
      ]
    },
    "requests": {
      "type": "integer"
    },
    "successful_requests": {
      "type": "integer"
    },
    "failed_requests": {
      "type": "integer"
    },
    "duration_seconds": {
      "type": [
        "number",
        "null"
      ]
    },
    "average_latency_ms": {
      "type": [
        "number",
        "null"
      ]
    },
    "p95_latency_ms": {
      "type": [
        "number",
        "null"
      ]
    },
    "tokens_per_second": {
      "type": [
        "number",
        "null"
      ]
    }
  },
  "required": [
    "platform",
    "workload",
    "requests",
    "successful_requests",
    "failed_requests"
  ]
}
